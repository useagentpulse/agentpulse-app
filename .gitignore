.build/
.swiftpm/

# macOS
.DS_Store
**/.DS_Store

# XcodeGen — generated project file (regenerate with `xcodegen generate`)
AgentPulse.xcodeproj/

# Secrets / creds
*.p12
*.mobileprovision
